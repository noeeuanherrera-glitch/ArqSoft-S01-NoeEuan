@model Catalogo1.Models.Item

@{
    ViewData["Title"] = "Expediente Operativo - CONFIDENCIAL";
}

<style>
    .report-container {
        font-family: 'Courier New', Courier, monospace;
        background-color: #f8f9fa;
        border: 1px dashed #b7b7b7;
        position: relative;
        overflow: hidden;
    }

    /* Sello decorativo de "Clasificado"
    .watermark-da {
        position: absolute;
        top: 10px;
        right: 10px;
        border: 3px solid rgba(230, 0, 18, 0.2);
        color: rgba(230, 0, 18, 0.2);
        padding: 5px;
        transform: rotate(15deg);
        font-weight: bold;
        text-transform: uppercase;
        pointer-events: none;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center border-bottom border-danger border-3 pb-3 mb-4">
        <h1 class="display-5 fw-bold text-uppercase m-0" style="letter-spacing: -1px;">
            <span class="text-danger">REGISTRO DA:</span> @Model.Titulo
        </h1>
        <div class="text-end">
            <span class="badge bg-danger p-2 text-uppercase d-block mb-1">Nivel: Restringido</span>
            <small class="text-muted">ID Único: #@(Model.Id.ToString("D4"))</small>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">
            <div class="card bg-dark border-danger border-2 shadow-lg">
                <img src="@Model.ImagenUrl" class="card-img-top img-fluid" alt="Registro Visual" style="filter: contrast(1.05); min-height: 350px; object-fit: cover;">
                <div class="card-body">
                    <div class="text-center text-white small">
                        <p class="mb-1 fw-bold text-uppercase">Estado: Activo / Verificado</p>
                        <div class="progress" style="height: 6px; background-color: #333;">
                            <div class="progress-bar bg-danger progress-bar-striped progress-bar-animated" style="width: 100%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7">
            <div class="p-4 bg-light border-start border-danger border-4 shadow-sm h-100 position-relative">
                
                <div class="watermark-da">CLASIFICADO</div>

                <h3 class="text-danger fw-bold border-bottom pb-2 mb-4 text-uppercase">
                    Especificaciones Tácticas
                </h3>
                
                <table class="table table-striped table-hover border-light">
                    <tbody>
                        <tr>
                            <th class="text-muted text-uppercase" style="width: 40%;">Categoría / Rol:</th>
                            <td class="fw-bold fs-5">@Model.Genero</td>
                        </tr>
                        <tr>
                            <th class="text-muted text-uppercase">Rango / Clasificación:</th>
                            <td class="fw-bold fs-5">@Model.Consola</td>
                        </tr>
                        <tr>
                            <th class="text-muted text-uppercase">Año de Alta:</th>
                            <td class="fw-bold fs-5">@Model.Ano</td>
                        </tr>
                    </tbody>
                </table>

                <h3 class="text-danger fw-bold border-bottom pb-2 mt-5 mb-3 text-uppercase">
                    Reporte de Campo
                </h3>
                <div class="p-3 report-container rounded shadow-sm">
                    <p class="lead m-0" style="white-space: pre-line; font-size: 1.1rem; color: #222;">
                        @Model.Descripcion
                    </p>
                </div>

                <div class="mt-4 pt-3 text-end" style="opacity: 0.7;">
                    <p class="small text-muted mb-0">Base de Datos Regional</p>
                    <p class="small text-muted fw-bold text-uppercase mb-0">Direct Attack - Sector Muna</p>
                    <small class="text-muted">Aprobado: MIKA / Supervisión: DA-HQ</small>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 mb-5 text-center">
        <a asp-action="Index" class="btn btn-outline-danger btn-lg px-5 shadow text-uppercase fw-bold">
            Cerrar Expediente Táctico
        </a>
    </div>
</div>