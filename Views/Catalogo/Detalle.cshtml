@model Catalogo1.Models.Item

@{
    bool esElite = Model.Titulo.Contains("Chisato") || Model.Titulo.Contains("Takina");
    string colorHex = esElite ? "#E60012" : "#FFD700"; // Rojo para ellas, dorado para otros
}

<style>
    body {
        background: #080808;
        color: #fff;
    }

    .terminal-frame {
        border: 2px solid @colorHex;
        background: rgba(20, 20, 20, 0.9);
        box-shadow: 0 0 30px rgba(0,0,0,1), inset 0 0 15px @(colorHex) 33;
        padding: 30px;
        margin-top: 30px;
        border-radius: 5px;
    }

    .desc-box {
        background: rgba(255,255,255,0.03);
        border-left: 4px solid @colorHex;
        padding: 20px;
        font-family: 'Consolas', monospace;
        color: #ddd;
        font-size: 1.1rem;
        line-height: 1.7;
    }

    .label-tech {
        color: @colorHex;
        font-weight: bold;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 2px;
        display: block;
    }
</style>

<div class="container">
    <div class="terminal-frame">
        <div class="row">
            <div class="col-md-5 text-center">
                <img src="@Model.ImagenUrl" class="img-fluid border border-secondary p-2" style="max-height: 400px; filter: contrast(1.1);">
                <div class="mt-3">
                    <span class="badge bg-dark border border-@((esElite ? "danger" : "warning")) p-2 w-100">
                        STATUS: ANALIZANDO OBJETIVO...
                    </span>
                </div>
            </div>

            <div class="col-md-7">
                <h1 class="display-5 fw-bold" style="text-shadow: 0 0 10px @colorHex;">@Model.Titulo</h1>
                <p class="text-muted mb-4">// ID_SISTEMA: DA-@Model.Id.ToString("D4")</p>

                <div class="row mb-4">
                    <div class="col-6">
                        <span class="label-tech">Clasificación</span>
                        <span class="h5">@Model.Genero</span>
                    </div>
                    <div class="col-6">
                        <span class="label-tech">Equipamiento</span>
                        <span class="h5">@Model.Consola</span>
                    </div>
                </div>

                <div class="desc-box">
                    <span class="label-tech mb-2">Resumen Operativo:</span>
                    @Model.Descripcion
                </div>

                <div class="mt-5 d-flex gap-2">
                    <a asp-action="Index" class="btn btn-outline-light px-4">VOLVER AL MENÚ</a>
                    <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-danger px-4" style="background:@colorHex; border:none;">EDITAR ARCHIVO</a>
                </div>
            </div>
        </div>
    </div>
</div>