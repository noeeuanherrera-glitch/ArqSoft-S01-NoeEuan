@model List<Catalogo1.Models.Item>

<div class="video-container shadow" style="position: relative; height: 350px; overflow: hidden; border-radius: 15px; margin-bottom: 30px; border: 2px solid #E60012; background-color: black;">
    <iframe style="position: absolute; top: 50%; left: 50%; width: 100%; height: 180%; transform: translate(-50%, -50%); pointer-events: none;"
            src="https://www.youtube.com/embed/VxR_BYPG7v4?autoplay=1&mute=1&controls=0&loop=1&playlist=VxR_BYPG7v4&rel=0&modestbranding=1"
            title="LycorisRecoil Intelligence System"
            frameborder="0"
            allow="autoplay; encrypted-media">
    </iframe>
    
    <div style="position: absolute; background: rgba(0,0,0,0.5); width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <h1 style="color: white; font-family: 'Segoe UI', Tahoma; font-weight: bold; text-shadow: 2px 2px 10px rgba(230, 0, 18, 0.9); letter-spacing: 3px;">
            LYCORISRECOIL INTELLIGENCE SYSTEM
        </h1>
        <p style="color: rgba(255,255,255,0.8); font-style: italic; letter-spacing: 1px;">Identificación de Agentes y Recursos Tácticos - Sector Muna</p>
    </div>
</div>

<h1 class="text-center my-4">Base de Datos Operativa</h1>

<div class="text-center mb-4">
    <a asp-action="Index" class="btn btn-outline-danger btn-sm">Todos</a>
    @foreach (var gen in ViewBag.Generos as List<string>)
    {
        <a asp-action="Index" asp-route-genero="@gen" class="btn btn-outline-dark btn-sm">@gen</a>
    }
</div>

<hr />

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm border-0" style="transition: transform .2s;">
                <img src="@item.ImagenUrl" class="card-img-top" alt="@item.Titulo" style="height: 250px; object-fit: cover; border-top-left-radius: 15px; border-top-right-radius: 15px;">
                
                <div class="card-body text-center bg-light">
                    <h5 class="card-title fw-bold">@item.Titulo</h5>
                    <span class="badge @(item.Genero == "Agente" ? "bg-danger" : "bg-dark") mb-2">@item.Genero</span>
                    <p class="small text-secondary">@item.Consola</p>
                    
                    <a asp-action="Detalle" asp-route-id="@item.Id" class="btn btn-danger btn-sm w-100">Ver Expediente</a>
                </div>
            </div>
        </div>
    }
</div>

<hr />

<div class="text-center mb-5">
    <a asp-action="Agregar" class="btn btn-success btn-lg shadow">+ Registrar Nuevo Agente Secreto</a>
</div>