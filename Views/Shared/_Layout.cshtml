<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Catalogo1</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Catalogo1.styles.css" asp-append-version="true" />

    <style>
        /* Fondo Global Oscuro con Cuadrícula */
        body {
            background-color: #0f0f0f !important;
            color: #e0e0e0 !important;
            background-image: 
                linear-gradient(rgba(230, 0, 18, 0.03) 1px, transparent 1px),
                linear-gradient(90deg, rgba(230, 0, 18, 0.03) 1px, transparent 1px);
            background-size: 30px 30px;
            min-height: 100vh;
        }

        /* Animación de Línea de Escaneo Táctica */
        body::after {
            content: "";
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 3px;
            background: rgba(230, 0, 18, 0.15);
            filter: blur(1px);
            animation: scanline 10s linear infinite;
            z-index: 9999;
            pointer-events: none;
        }

        @@keyframes scanline {
            0% { transform: translateY(-100px); }
            100% { transform: translateY(100vh); }
        }

        /* Ajuste de Textos para Visibilidad */
        h1, h2, h3, h4, .display-4, .navbar-brand, .nav-link {
            color: #ffffff !important;
        }

        /* Barra de Navegación Estilo DA */
        .navbar {
            background-color: #1a1a1a !important;
            border-bottom: 2px solid #E60012 !important;
            box-shadow: 0 4px 12px rgba(230, 0, 18, 0.2) !important;
        }

        /* ESTADO ACTIVO: Esto es lo que te dará puntos extra */
        .nav-link.active-lycoris {
            color: #E60012 !important;
            font-weight: bold;
            text-shadow: 0 0 10px rgba(230, 0, 18, 0.8);
            border-bottom: 2px solid #E60012;
        }

        footer {
            background-color: #0f0f0f;
            border-top: 1px solid #333 !important;
        }
    </style>
</head>
<body>
    <header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm mb-3">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold text-danger" asp-area="" asp-controller="Catalogo" asp-action="Index">LYCORECO SIGO</a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon" style="filter: invert(1);"></span>
            </button>
            
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    @{
                        // Lógica para detectar la página actual
                        var controller = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var action = ViewContext.RouteData.Values["Action"]?.ToString();
                    }

                    <li class="nav-item">
                        <a class="nav-link @(controller == "Catalogo" ? "active-lycoris" : "text-white")" 
                           asp-area="" asp-controller="Catalogo" asp-action="Index">Base de Datos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(controller == "Home" && action == "Privacy" ? "active-lycoris" : "text-white")" 
                           asp-area="" asp-controller="Home" asp-action="Privacy">Privacidad</a>
                    </li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container text-center">
            &copy; 2026 - DA INTELLIGENCE SYSTEM - MUNA, YUC - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>